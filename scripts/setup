#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Install uv if not available
if ! command -v uv &> /dev/null; then
    echo "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
fi

# Sync all dependencies (including dev group)
uv sync --group dev

# Install pre-commit hooks
uv run pre-commit install
